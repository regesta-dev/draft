{
  "name": "regesta-workspace",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "build": "pnpm -r build",
    "ci:smoke": "pnpm test -- --run && pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm docs:build && pnpm smoke:load:ci",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "dev:server": "pnpm --filter @regesta/server dev",
    "lint": "eslint --cache .",
    "lint:fix": "pnpm run lint --fix",
    "format": "prettier --cache --write .",
    "format:check": "prettier --cache --check .",
    "smoke:docker": "node scripts/docker-smoke.mjs",
    "smoke:load": "node --conditions=regesta-source scripts/load-smoke.mjs",
    "smoke:load:ci": "node scripts/load-smoke-ci.mjs",
    "smoke:load:validate": "node scripts/validate-load-smoke-result.mjs",
    "test": "vitest",
    "typecheck": "tsgo --noEmit && pnpm --filter @regesta/server typecheck"
  },
  "devDependencies": {
    "@sxzz/eslint-config": "^8.1.0",
    "@sxzz/prettier-config": "^2.3.1",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260527.2",
    "eslint": "^10.4.1",
    "markdown-it-task-lists": "^2.1.1",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.7"
  },
  "prettier": "@sxzz/prettier-config"
}
